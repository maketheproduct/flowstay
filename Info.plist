	<string>Flowstay needs microphone access to capture your voice for dictation. All processing is done locally on your Mac for privacy.</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSRequiresAquaSystemAppearance</key>
	<false/>
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Dictate with Flowstay</string>
			</dict>
			<key>NSMessage</key>
			<string>dictateText</string>
			<key>NSPortName</key>
			<string>Flowstay</string>
			<key>NSReturnTypes</key>
			<array>
				<string>NSStringPboardType</string>
			</array>
			<key>NSSendTypes</key>
			<array>
				<string>NSStringPboardType</string>
			</array>
		</dict>
	</array>
